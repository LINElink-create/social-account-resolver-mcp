MONGODB_URI=mongodb+srv://user:password@example.mongodb.net/?appName=Cluster0
MONGODB_DATABASE=social_account_resolver

WEIBO_COOKIE=
XHS_COOKIE=

TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_REGION=ap-guangzhou

SEARCH_CACHE_TTL_SECONDS=86400
HTTP_TIMEOUT_SECONDS=12

# Xiaohongshu browser mode:
# - Leave XHS_BROWSER_TYPE empty to use Edge on Windows and Chrome on Linux/macOS.
# - Set XHS_BROWSER_HEADLESS=true for most Linux servers.
XHS_BROWSER_ENABLED=true
XHS_BROWSER_TYPE=
XHS_BROWSER_HEADLESS=false
XHS_BROWSER_TIMEOUT_SECONDS=20

# Windows / Edge
XHS_EDGE_USER_DATA_DIR=D:\MCP\SearchCoser\edge-xhs-profile
XHS_EDGE_PROFILE=Default
XHS_EDGE_BINARY=
XHS_EDGE_DRIVER_PATH=

# Linux / Chrome or Chromium
XHS_CHROME_USER_DATA_DIR=/opt/social-account-resolver/xhs-chrome-profile
XHS_CHROME_PROFILE=Default
XHS_CHROME_BINARY=/usr/bin/google-chrome
XHS_CHROME_DRIVER_PATH=
